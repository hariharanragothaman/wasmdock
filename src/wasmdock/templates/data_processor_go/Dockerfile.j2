# syntax=docker/dockerfile:1
# WasmDock: Go (TinyGo) data processor -- multi-stage build
# Runtime: {{ runtime }} ({{ runtime_containerd }})

FROM --platform=$BUILDPLATFORM tinygo/tinygo:0.34.0 AS build

WORKDIR /src
COPY go.mod ./
COPY main.go ./

# Compile Go to a WASI Preview 1 module with TinyGo.
RUN tinygo build -o /{{ project_name_snake }}.wasm -target=wasip1 .

# -------------------------------------------------------------------
# Minimal WASM image
# -------------------------------------------------------------------
FROM scratch

COPY --from=build /{{ project_name_snake }}.wasm /{{ project_name_snake }}.wasm

ENTRYPOINT ["/{{ project_name_snake }}.wasm"]
