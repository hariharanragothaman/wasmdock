[package]
name = "{{ project_name_snake }}"
version = "0.1.0"
edition = "2021"

[[bin]]
name = "{{ project_name_snake }}"
path = "src/main.rs"

[dependencies]
wasi = "0.13"
serde = { version = "1", features = ["derive"] }
serde_json = "1"

[profile.release]
opt-level = "s"
lto = true
strip = "debuginfo"
